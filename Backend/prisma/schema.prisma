generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  datasets     Dataset[]
}

model Dataset {
  id                String             @id @default(uuid())
  userId            String?
  name              String
  status            String             @default("Processing") // Processing, Ready, Failed
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User?              @relation(fields: [userId], references: [id])
  files             File[]
  complianceReports ComplianceReport[]
}

model File {
  id           String     @id @default(uuid())
  datasetId    String
  originalName String
  storedPath   String
  format       String
  sizeBytes    Int
  status       String     @default("Pending")
  dataset      Dataset    @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  metadata     Metadata[]
}

model Metadata {
  id               String @id @default(uuid())
  fileId           String
  tags             String @default("[]") // JSON stringified array
  language         String @default("en")
  sensitiveFlags   String @default("[]") // JSON stringified array
  confidenceScores String @default("{}") // JSON stringified object
  file             File   @relation(fields: [fileId], references: [id], onDelete: Cascade)
}

model ComplianceReport {
  id                 String   @id @default(uuid())
  datasetId          String
  overallScore       Int      @default(0)
  violations         String   @default("[]") // JSON
  warnings           String   @default("[]") // JSON
  autoFixSuggestions String   @default("[]") // JSON
  createdAt          DateTime @default(now())
  dataset            Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)
}
